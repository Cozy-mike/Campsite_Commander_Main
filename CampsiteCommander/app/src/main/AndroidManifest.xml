<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.campsitecommander">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.CampsiteCommander"
        android:supportsRtl="true">

        <!-- SplashActivity is the LAUNCHER (first screen) -->
        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.CampsiteCommander.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main hub screen -->
        <activity android:name=".MainActivity" android:exported="false"/>

        <!-- Add gear form screen -->
        <activity android:name=".AddGearActivity" android:exported="false"/>

        <!-- Detailed gear list screen -->
        <activity android:name=".DetailedViewActivity" android:exported="false"/>

    </application>

</manifest>
